{
  "all-versions": [
    {
      "extension": "revapi.filter",
      "configuration": {
        "elements": {
          "exclude": [
            ".* com\\.vaadin\\.flow\\..*"
          ]
        }
      }
    },
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": "java.class.externalClassExposedInAPI",
            "new": ".*org\\.linkki\\.core\\..*",
            "justification": "LIN-2651/LIN-2652"
          },
          {
            "regex": true,
            "code": "java.class.externalClassExposedInAPI",
            "new": ".*org\\.linkki\\.util\\..*",
            "justification": "LIN-2651/LIN-2652"
          }
        ]
      }
    }
  ],
  "2.10.0": [
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "code": "java.method.visibilityIncreased",
            "old": "method void org.linkki.core.binding.descriptor.BindingDescriptor::<init>(org.linkki.core.binding.descriptor.property.BoundProperty, java.util.List<org.linkki.core.binding.descriptor.aspect.LinkkiAspectDefinition>, org.linkki.core.binding.descriptor.messagehandler.LinkkiMessageHandler)",
            "new": "method void org.linkki.core.binding.descriptor.BindingDescriptor::<init>(org.linkki.core.binding.descriptor.property.BoundProperty, java.util.List<org.linkki.core.binding.descriptor.aspect.LinkkiAspectDefinition>, org.linkki.core.binding.descriptor.messagehandler.LinkkiMessageHandler)",
            "oldVisibility": "private",
            "newVisibility": "public",
            "justification": "LIN-4781/LIN-4840 Expose constructor to allow custom message handlers"
          }
        ]
      }
    }
  ]
}
