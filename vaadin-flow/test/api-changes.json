{
  "all-versions": [
    {
      "extension": "revapi.filter",
      "configuration": {
        "elements": {
          "exclude": [
            ".*org\\.junit\\.jupiter\\.api\\..*"
          ]
        },
        "archives": {
          "exclude": [
            "org.linkki-framework:linkki-core:jar.*",
            "com.vaadin:.*"
          ]
        }
      }
    },
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": "java.class.externalClassExposedInAPI",
            "justification": "Not API breaking"
          },
          {
            "regex": true,
            "code": "java.annotation.attributeValueChanged",
            "annotationType": "kotlin\\..*",
            "justification": "Ignore kotlin API breaks"
          },
          {
            "regex": true,
            "code": "java\\.missing\\.(old|new)Class",
            "justification": "Not API breaking"
          },
          {
            "regex": true,
            "code": "java.class.nonPublicPartOfAPI",
            "package": "^(?!.*linkki).*$",
            "justification": "Binary compatible"
          },
          {
            "regex": true,
            "code": "java.annotation.attributeValueChanged",
            "annotationType": "com.vaadin.flow.component.dependency.NpmPackage.*",
            "package": ".*com\\.vaadin\\.flow\\..*",
            "justification": "Binary compatible, only affects frontend bundle"
          }
        ]
      }
    }
  ],
  "2.10.0": [
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "ignore": true,
            "code": "java.annotation.attributeValueChanged",
            "old": "class com.github.mvysny.kaributesting.v10.Routes",
            "new": "class com.github.mvysny.kaributesting.v10.Routes",
            "annotationType": "kotlin.Metadata",
            "attribute": "d1",
            "justification": "JTS-2906 Version updated to 2.6.2"
          }
        ]
      }
    }
  ]
}