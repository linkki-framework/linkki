{
  "all-versions": [
    {
      "extension": "revapi.filter",
      "configuration": {
        "archives": {
          "exclude": [
            "org.linkki-framework:linkki-core:jar.*",
            "org.linkki-framework:linkki-application-framework-vaadin-flow:jar.*",
            "com.vaadin:.*"
          ]
        }
      }
    },
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": "java.class.externalClassExposedInAPI",
            "new": "^(?!.*org\\.linkki).*$",
            "justification": "Ignore for classes in dependencies"
          },
          {
            "regex": true,
            "code": "java.class.nonPublicPartOfAPI",
            "package": "^(?!.*linkki).*$",
            "justification": "Binary compatible"
          },
          {
            "regex": true,
            "code": "java\\.missing\\.(old|new)Class",
            "justification": "Not API breaking"
          }
        ]
      }
    }
  ],
  "2.10.0": [
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": "java.method.numberOfParametersChanged",
            "new": ".*Component::scrollIntoView.*",
            "justification": "Vaadin 25.0"
          },
          {
            "regex": true,
            "code": "java.method.visibilityReduced",
            "new": "method .* org\\.linkki\\.search\\.annotation\\..*::createComponentValueSetter\\(org\\.linkki\\.core\\.binding\\.wrapper\\.ComponentWrapper\\)",
            "oldVisibility": "public",
            "newVisibility": "protected",
            "justification": "createComponentValueSetter is an internal implementation detail of AspectDefinitions and should not be part of the public API"
          }
        ]
      }
    }
  ]
}
