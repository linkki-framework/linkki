{
  "all-versions": [
    {
      "extension": "revapi.filter",
      "configuration": {
        "archives": {
          "exclude": [
            "org.linkki-framework:linkki-core:jar.*",
            "com.vaadin:.*"
          ]
        }
      }
    },
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": "java.class.externalClassExposedInAPI",
            "new": "^(?!.*org\\.linkki).*$",
            "justification": "Ignore for classes in dependencies"
          },
          {
            "regex": true,
            "code": "java.class.nonPublicPartOfAPI",
            "package": "^(?!.*linkki).*$",
            "justification": "Binary compatible"
          },
          {
            "regex": true,
            "code": "java.annotation.attributeValueChanged",
            "annotationType": "com.vaadin.flow.component.dependency.NpmPackage.*",
            "package": ".*com\\.vaadin\\.flow\\..*",
            "justification": "Binary compatible, only affects frontend bundle"
          },
          {
            "regex": true,
            "code": "java\\.missing\\.(old|new)Class",
            "justification": "Not API breaking"
          }
        ]
      }
    }
  ],
  "2.10.0": [
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": "java.method.numberOfParametersChanged",
            "new": ".*Component::scrollIntoView.*",
            "justification": "Vaadin 25.0"
          },
          {
            "code": "java.method.removed",
            "old": "method com.vaadin.flow.shared.Registration com.vaadin.flow.component.shared.HasClientValidation::addClientValidatedEventListener(com.vaadin.flow.component.ComponentEventListener<com.vaadin.flow.component.shared.HasClientValidation.ClientValidatedEvent>) @ org.linkki.core.vaadin.component.base.LinkkiCheckBox",
            "justification": "Vaadin 25.0 https://github.com/vaadin/flow-components/pull/7583"
          },
          {
            "code": "java.class.removed",
            "old": "class org.linkki.core.ui.nested.annotation.UINestedComponent.NestedAspecDefinitionCreator",
            "justification": "LIN-2733/LIN-4698"
          },
          {
            "code": "java.annotation.attributeValueChanged",
            "old": "@interface org.linkki.core.ui.nested.annotation.UINestedComponent",
            "new": "@interface org.linkki.core.ui.nested.annotation.UINestedComponent",
            "annotationType": "org.linkki.core.binding.descriptor.aspect.annotation.LinkkiAspect",
            "attribute": "value",
            "oldValue": "org.linkki.core.ui.nested.annotation.UINestedComponent.NestedAspecDefinitionCreator.class",
            "newValue": "org.linkki.core.ui.nested.annotation.UINestedComponent.NestedAspectDefinitionCreator.class",
            "justification": "LIN-2733/LIN-4698"
          }
        ]
      }
    }
  ]
}