{
  "all-versions": [
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": "java.class.externalClassExposedInAPI",
            "justification": "Binary compatible"
          },
          {
            "regex": true,
            "code": "java.class.nonPublicPartOfAPI",
            "package": "^(?!.*linkki).*$",
            "justification": "Binary compatible"
          },
          {
            "regex": true,
            "code": ".*",
            "annotationType": "com\\.vaadin\\.flow\\.component\\.dependency\\.NpmPackage.*",
            "justification": "Binary compatible, only affects frontend bundle"
          },
          {
            "regex": true,
            "code": ".*",
            "annotationType": "com\\.vaadin\\.flow\\.component\\.dependency\\.JsModule.*",
            "justification": "Binary compatible, only affects frontend bundle"
          },
          {
            "regex": true,
            "code": "java\\.missing\\.(old|new)Class",
            "justification": "Not API breaking"
          },
          {
            "regex": true,
            "code": ".*",
            "package": "com\\.vaadin\\.flow\\.component\\.internal",
            "justification": "Internal API of Vaadin"
          }
        ]
      }
    }
  ],
  "2.10.0": [
    {
      "extension": "revapi.differences",
      "configuration": {
        "ignore": true,
        "differences": [
          {
            "regex": true,
            "code": ".*",
            "newType": ".*jackson\\.databind.*",
            "justification": "Vaadin 25.0 https://github.com/vaadin/flow-components/pull/8055"
          }
        ]
      }
    }
  ]
}